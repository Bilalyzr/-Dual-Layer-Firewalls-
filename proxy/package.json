{
  "name": "dual-layer-proxy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Node.js AI Firewall proxy — intercepts prompts, runs heuristics + ML classification, batches keystroke telemetry.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "start:gateway": "node services/gateway.js",
    "start:firewall": "node services/firewall-svc.js",
    "start:agent": "node services/agent-svc.js",
    "start:biometric": "node services/biometric-svc.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb": "^6.12.0",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
