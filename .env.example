# =============================================================================
# Unified Dual-Layer AI Firewall — Environment Configuration
# Copy to .env and fill in. All values have safe defaults for local demo.
# =============================================================================

# ---- LLM backend (OpenAI-compatible) ----
# Works with OpenAI, Groq, OpenRouter, Together, or local Ollama / LM Studio.
# Example OpenAI:    LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o-mini
# Example Groq:      LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.1-8b-instant
# Example Ollama:    LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL=llama3.2  (key ignored)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini
# Per-request LLM timeout in ms (default 45000). Increase if your provider is
# slow; the proxy returns 502 + a friendly frontend message on timeout.
LLM_TIMEOUT_MS=45000

# ---- MongoDB ----
MONGO_URI=mongodb://mongo:27017/firewall
MONGO_URI_LOCAL=mongodb://localhost:27017/firewall

# ---- Service ports ----
# NOTE: engine uses 8011 (8001 collides with Docker Desktop on some machines).
PROXY_PORT=4000
ENGINE_PORT=8011
CLIENT_PORT=5173

# ---- Engine URL (from proxy's perspective inside docker) ----
ENGINE_URL=http://engine:8011

# ---- Firewall (Layer 1) ----
# shadow = log only, do not block. enforce = block threats.
FIREWALL_MODE=shadow
# Classifier probability threshold above which a prompt is treated as a threat (0..1)
FIREWALL_THRESHOLD=0.65
# Fraction of low-confidence ALLOWED traffic to retain for adversarial review (Req 1.5)
ADVERSARIAL_SAMPLE_RATE=0.05

# ---- Llama Guard 4 safety layer (Tier 2 EPIC C) ----
# A dedicated safety-model pass on input + output, complementing regex + classifier.
# Disabled by default (no endpoint required for the base demo).
LLAMAGUARD_ENABLED=false
# OpenAI-compatible endpoint serving a Llama-Guard model. Falls back to LLM_BASE_URL.
#   Groq:     https://api.groq.com/openai/v1   model meta-llama/llama-guard-4-12b
#   Together: https://api.together.xyz/v1      model meta-llama/Llama-Guard-4-12B
LLAMAGUARD_URL=
LLAMAGUARD_MODEL=meta-llama/llama-guard-4-12b
# API key for the guard endpoint. Falls back to LLM_API_KEY if unset.
LLAMAGUARD_API_KEY=

# ---- Biometrics (Layer 2) ----
# shadow = score only, never step-up. enforce = (Tier 2) require WebAuthn step-up.
BIOMETRIC_MODE=shadow
# Minimum keystroke events before a user leaves cold-start (Req 3.6)
BIOMETRIC_MIN_SAMPLES=120
# z-score magnitude above which a session is flagged anomalous
BIOMETRIC_Z_THRESHOLD=2.5
# Trust score (0..100) at/below which enforce mode triggers FIDO2 step-up (EPIC B)
BIOMETRIC_STEPUP_THRESHOLD=50

# ---- Sessions & identity (Tier 2 EPIC A) ----
# HMAC secret used to sign opaque session tokens. MUST be set (>=16 chars) before
# any non-local deploy; a marked-insecure dev default is used if unset.
SESSION_SECRET=dev-insecure-session-secret-change-me

# ---- FIDO2 / WebAuthn step-up (Tier 2 EPIC B) ----
# Relying Party id = the site's registrable domain (no scheme/port). Localhost dev: "localhost".
WEBAUTHN_RP_ID=localhost
# Human-readable Relying Party name shown in the authenticator prompt.
WEBAUTHN_RP_NAME=Dual-Layer AI Firewall
# Full origin the browser sends assertions from (scheme + host + port).
WEBAUTHN_ORIGIN=http://localhost:5174

# =============================================================================
# EPIC D — Security NFRs (TLS 1.3 in transit, AES-256 at rest)
# =============================================================================

# At-rest field encryption (AES-256-GCM). Protects prompt snippets in alerts/
# samples and keystroke timing in baselines so a Mongo dump exposes no raw PII.
# Leave unset to DISABLE (transparent pass-through — fine for local dev).
# Accepts: a 32-byte base64 key, a 64-char hex string, or any passphrase
# (key-derived via scrypt). Generate one with:
#   openssl rand -base64 32
APP_ENCRYPTION_KEY=

# TLS termination. Set ENABLE_TLS=true and run `bash scripts/gen-certs.sh` to
# enable the edge nginx proxy (TLS 1.3 only, HTTP→HTTPS redirect) in docker.
#   docker compose --profile tls up
# For PRODUCTION, replace tls/cert.pem + tls/key.pem with Let's Encrypt certs.
ENABLE_TLS=false

# =============================================================================
# EPIC G — Distributed microservices (gateway / firewall / agent / biometric)
#
# The default single-container monolith needs NONE of these. They are consumed by
# docker-compose.micro.yml, which splits the proxy into independently-scalable
# services wired together by a Redis event bus:
#   docker compose -f docker-compose.micro.yml up --build
#   docker compose -f docker-compose.micro.yml up --scale firewall-svc=3
# =============================================================================

# Which slice this process runs. Unset/"all" = monolith (default). The service
# entrypoints in proxy/services/ set this for you; only override for manual runs.
#   all | gateway | firewall | agent | biometric
SERVICE_ROLE=all
# Human-readable label used in structured logs + the `service` metric label.
# SERVICE_NAME=proxy
# Log output: JSON (default, aggregator-friendly) or "pretty" for local dev.
LOG_FORMAT=
LOG_LEVEL=info

# Redis event bus. Unset = in-process SSE fan-out (monolith). Set = distributed
# fan-out so an event from any service reaches every gateway replica's clients.
REDIS_URL=
EVENT_BUS_CHANNEL=firewall:events

# Service-to-service URLs (used by the gateway to forward, and by firewall-svc to
# delegate agentic prompts to agent-svc). Docker DNS names in the micro compose.
FIREWALL_SVC_URL=http://firewall-svc:4000
BIOMETRIC_SVC_URL=http://biometric-svc:4000
AGENT_SVC_URL=http://agent-svc:4000
